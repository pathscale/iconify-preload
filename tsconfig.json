{
	"compilerOptions": {
		"target": "ES2020",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"esModuleInterop": true,
		"types": ["bun"],
		"strict": true,
		"declaration": true,
		"outDir": "dist",
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"rootDir": "./src"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
